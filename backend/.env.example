DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=product_gallery
DB_USERNAME=product_gallery
DB_PASSWORD=replace_with_real_password
# 可选：连接超时（毫秒），默认已在 application.yml 内置 connectTimeout=10000 & socketTimeout=60000

OSS_ENABLED=true
OSS_ENDPOINT=https://oss-us-west-1.aliyuncs.com
OSS_BUCKET_NAME=example-bucket
OSS_ACCESS_KEY_ID=replace_with_real_access_key_id
OSS_ACCESS_KEY_SECRET=replace_with_real_access_key_secret
OSS_BUCKET_DOMAIN=

SHARE_BASE_URL=http://localhost:8080

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_TOKEN_EXPIRE_HOURS=24
