<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.szwego.gallery.mapper.ProductMapper">

    <sql id="galleryWhere">
        <where>
            <if test="status != null">
                p.status = #{status}
            </if>
            <if test="topOnly != null and topOnly == 1">
                AND p.is_top = 1
            </if>
            <if test="sku != null and sku != ''">
                AND p.sku LIKE CONCAT('%', #{sku}, '%')
            </if>
            <if test="categoryIds != null and categoryIds.size() > 0">
                AND p.category_id IN
                <foreach collection="categoryIds" item="categoryId" open="(" separator="," close=")">
                    #{categoryId}
                </foreach>
            </if>
            <if test="keyword != null and keyword != ''">
                AND (
                    p.title LIKE CONCAT('%', #{keyword}, '%')
                    OR p.description LIKE CONCAT('%', #{keyword}, '%')
                    OR p.sku LIKE CONCAT('%', #{keyword}, '%')
                    <if test="translatedMatches != null and translatedMatches.size() > 0">
                        OR p.id IN
                        <foreach collection="translatedMatches" item="translatedId" open="(" separator="," close=")">
                            #{translatedId}
                        </foreach>
                    </if>
                )
            </if>
        </where>
    </sql>

    <select id="countForGalleryPage" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM product p
        <include refid="galleryWhere"/>
    </select>

    <select id="selectGalleryPageIds" resultType="java.lang.Long">
        SELECT p.id
        FROM product p
        <include refid="galleryWhere"/>
        ORDER BY
            p.is_top DESC,
            UNIX_TIMESTAMP(p.update_time) DESC,
            UNIX_TIMESTAMP(p.create_time) DESC,
            p.id DESC
        LIMIT #{offset}, #{size}
    </select>
</mapper>
